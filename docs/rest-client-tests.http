# PoT Blockchain API Tests
# VS Code Rest Client Test File
# 
# 使用说明:
# 1. 安装 VS Code Rest Client 扩展
# 2. 确保 PoT 服务器运行在 localhost:18025 (HTTP API)
# 3. 确保 BCI 服务器运行在 localhost:9866 (gRPC API)
# 4. 点击每个请求上方的 "Send Request" 按钮执行测试
# 5. 根据需要修改测试数据
#
# 重要提示:
# - PoT 使用 UTXO 模型，需要先通过 gRPC 获取可用的 UTXO
# - 使用后量子密码学 (PQC) 签名，签名数据较大 (~4KB)
# - 地址为 PQC 公钥的十六进制表示 (~96字节)
# - 交易ID留空时系统会自动计算哈希值

# 设置基础变量
@baseUrl = http://localhost:18025
@contentType = application/json

###############################################################################
# 1. 健康检查接口测试
###############################################################################

### 健康检查 - Hello World
POST {{baseUrl}}/api/hello
Content-Type: {{contentType}}

{}

###############################################################################
# 2. 获取区块高度测试
###############################################################################

### 获取当前区块高度
GET {{baseUrl}}/api/getblockheight

###############################################################################
# 3. 创建锁定交易测试
###############################################################################

### 创建锁定交易 - 基础测试 (基于实际UTXO模型)
POST {{baseUrl}}/api/createlocktransaction
Content-Type: {{contentType}}

{
  "transaction": {
    "txid": "",
    "txInputs": [
      {
        "txid": "0xa1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456",
        "voutput": "0",
        "scriptSig": "0x308201a0300d06092a864886f70d01010105000382018d00308201880282018100c5d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0",
        "value": "1000000",
        "address": "0x5f41dce11f9b9a19b92c6dad6d2b8b8f00000000000000007695cd781cde492f5254a88066024237129eb549b0864c8f",
        "bciType": "1"
      }
    ],
    "txOutputs": [
      {
        "address": "0x742d35cc6e11111111111111111111111111111111111111111111111111",
        "value": "995000",
        "interest": "0",
        "proof": "0x",
        "lockTime": "1672531200",
        "bciType": "1",
        "data": "0x",
        "burnLock": "0",
        "rate": "0.05"
      }
    ],
    "transactionFee": "5000"
  },
  "type": "CreateLockTransaction"
}

