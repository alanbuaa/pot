# 7. 错误测试用例
###############################################################################

### 错误测试 - 无效的十六进制格式
POST {{baseUrl}}/api/createlocktransaction
Content-Type: {{contentType}}

{
  "transaction": {
    "txid": "invalid_hex_string",
    "txInputs": [
      {
        "txid": "also_invalid",
        "voutput": "0",
        "scriptSig": "0x4730440220123456789abcdef",
        "value": "1000000",
        "address": "not_hex",
        "bciType": "1"
      }
    ],
    "txOutputs": [
      {
        "address": "0x742d35cc6e11111111111111111111111111111111111111111111111111",
        "value": "999000",
        "interest": "0",
        "proof": "0x",
        "lockTime": "1640995200",
        "bciType": "1",
        "data": "0x",
        "burnLock": "0",
        "rate": "0.0"
      }
    ],
    "transactionFee": "1000"
  },
  "type": "CreateLockTransaction"
}

### 错误测试 - 无效的 JSON 格式
POST {{baseUrl}}/api/createlocktransaction
Content-Type: {{contentType}}

{
  "transaction": {
    "txid": "0x1234567890abcdef",
    "txInputs": [
      // 这个注释会导致 JSON 解析错误
      {
        "txid": "0xabcdef1234567890",
        "voutput": "0"
      }
    ],
    "txOutputs": []
  }
}

### 错误测试 - 缺少必要字段
POST {{baseUrl}}/api/createlocktransaction
Content-Type: {{contentType}}

{
  "transaction": {
    "txid": "0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef",
    "txInputs": [],
    "txOutputs": [],
    "transactionFee": "1000"
  },
  "type": "CreateLockTransaction"
}

### 错误测试 - 数值格式错误
POST {{baseUrl}}/api/createlocktransaction
Content-Type: {{contentType}}

{
  "transaction": {
    "txid": "0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef",
    "txInputs": [
      {
        "txid": "0xabcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890",
        "voutput": "not_a_number",
        "scriptSig": "0x4730440220123456789abcdef",
        "value": "invalid_value",
        "address": "0x742d35cc6e00000000000000000000000000000000000000000000000000",
        "bciType": "not_number"
      }
    ],
    "txOutputs": [
      {
        "address": "0x742d35cc6e11111111111111111111111111111111111111111111111111",
        "value": "999000",
        "interest": "0",
        "proof": "0x",
        "lockTime": "1640995200",
        "bciType": "1",
        "data": "0x",
        "burnLock": "0",
        "rate": "invalid_rate"
      }
    ],
    "transactionFee": "1000"
  },
  "type": "CreateLockTransaction"
}

